# ─── Django Core Configuration ───────────────────────────
# REQUIRED: Generate a secure key at https://djecrety.ir
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-alb-dns.us-east-1.elb.amazonaws.com,api.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://your-alb-dns.us-east-1.elb.amazonaws.com,https://api.yourdomain.com

# ─── Relational Database (PostgreSQL / RDS) ──────────────
DB_NAME=finovo_db
DB_USER=postgres
DB_PASSWORD=your-rds-password
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
CONN_MAX_AGE=600

# ─── AWS Configuration ──────────────────────────────────
# Leave empty if using IAM instance profile on EC2 (recommended)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
DYNAMO_TABLE_NAME=finovo_projections
AWS_REGION=us-east-1

# ─── CORS (for web frontends) ───────────────────────────
# Leave empty to allow all origins (mobile apps like React Native)
CORS_ALLOWED_ORIGINS=

# ─── Email / SMTP Service ───────────────────────────────
# For Gmail, use an "App Password" (not your main password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
